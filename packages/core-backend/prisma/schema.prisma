generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prov_Category {
  id          String          @id @default(uuid())
  name        String          @unique
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  providers   Prov_Provider[]
}

model Prov_Provider {
  id             String             @id @default(uuid())
  businessName   String
  taxId          String             @unique
  address        String?
  discountRate   Float              @default(0.0)
  categoryId     String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  postalCode     String?
  province       String?
  taxCondition   String?
  isCtaCte       Boolean            @default(true)
  expirationDays Int                @default(0)
  netAmountCode  String?
  fantasyName    String?
  bankAccounts   Prov_BankAccount[]
  contacts       Prov_Contact[]
  invoices       Prov_Invoice[]
  payments       Prov_Payment[]
  category       Prov_Category?     @relation(fields: [categoryId], references: [id])
}

model Prov_Contact {
  id         String        @id @default(uuid())
  name       String
  phone      String?
  email      String?
  role       String?
  providerId String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  provider   Prov_Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model Prov_BankAccount {
  id            String        @id @default(uuid())
  bankName      String
  accountType   String
  accountNumber String?
  cbuCvu        String?
  alias         String?
  providerId    String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  provider      Prov_Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model Prov_Invoice {
  id               String             @id @default(uuid())
  invoiceType      InvoiceType        @default(FACTURA_A)
  pointOfSale      String
  invoiceNumber    String
  issueDate        DateTime
  dueDate          DateTime?
  netAmount        Float
  taxAmount        Float
  nonTaxedAmount   Float              @default(0.0)
  totalAmount      Float
  status           InvoiceStatus      @default(PENDIENTE)
  providerId       String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  isCtaCte         Boolean            @default(true)
  perceptionAmount Float              @default(0.0)
  receptionDate    DateTime?
  ivaNumber        Int?
  ivaPeriod        String?
  provider         Prov_Provider      @relation(fields: [providerId], references: [id])
  paymentsItems    Prov_PaymentItem[]

  @@unique([providerId, pointOfSale, invoiceNumber])
}

model Prov_Payment {
  id             String             @id @default(uuid())
  paymentDate    DateTime           @default(now())
  totalAmount    Float
  paymentMethod  PaymentMethod
  referenceNotes String?
  providerId     String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  discountAmount Float              @default(0.0)
  number         String?
  status         PaymentStatus      @default(CONFIRMADO)
  checks         Prov_Check[]
  provider       Prov_Provider      @relation(fields: [providerId], references: [id])
  invoicesPaid   Prov_PaymentItem[]
}

model Prov_PaymentItem {
  id         String       @id @default(uuid())
  amountPaid Float
  paymentId  String
  invoiceId  String
  createdAt  DateTime     @default(now())
  invoice    Prov_Invoice @relation(fields: [invoiceId], references: [id])
  payment    Prov_Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Prov_Check {
  id          String       @id @default(uuid())
  checkNumber String
  bankName    String
  issuerName  String
  issueDate   DateTime
  dueDate     DateTime
  amount      Float
  paymentId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  status      CheckStatus  @default(PENDIENTE)
  payment     Prov_Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Core_User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  picture   String?
  role      UserRole  @default(VIEWER)
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Core_Parameter {
  id        String   @id @default(uuid())
  category  String
  key       String?
  value     String
  label     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, key])
}

model Core_Notification {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String   @default("INFO")
  isRead      Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Core_BusinessConfig {
  id           String   @id @default("singleton")
  name         String   @default("Clorymetal SRL")
  taxId        String   @default("00-00000000-0")
  address      String   @default("Dirección Ficticia 123")
  city         String   @default("Resistencia")
  province     String   @default("Chaco")
  phone        String   @default("3624-000000")
  email        String   @default("contacto@clorymetal.com.ar")
  vatCondition String   @default("Responsable Inscripto")
  logoUrl      String?
  updatedAt    DateTime @updatedAt
}

model Emp_Employee {
  id            Int                @id @default(autoincrement())
  name          String
  payType       PayType            @default(MONTHLY)
  baseSalary    Float
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  area          String             @default("TALLER")
  address       String?
  cuil          String?            @unique
  password      String?
  phone         String?
  username      String?            @unique
  advances      Emp_Advance[]
  salaryPeriods Emp_SalaryPeriod[]
  repoTasks     Repo_Task[]
}

model Emp_SalaryPeriod {
  id                Int           @id @default(autoincrement())
  employeeId        Int
  periodYear        Int
  periodMonth       Int
  baseSalary        Float
  firstInstallment  Float?
  secondInstallment Float?
  totalAdvances     Float         @default(0)
  balance           Float
  isClosed          Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  advances          Emp_Advance[]
  employee          Emp_Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, periodYear, periodMonth])
}

model Emp_Advance {
  id             Int              @id @default(autoincrement())
  employeeId     Int
  periodId       Int
  date           DateTime         @default(now())
  cashAmount     Float            @default(0)
  checkAmount    Float            @default(0)
  transferAmount Float            @default(0)
  totalAmount    Float
  accumulated    Float
  balance        Float
  notes          String?
  createdAt      DateTime         @default(now())
  employee       Emp_Employee     @relation(fields: [employeeId], references: [id])
  period         Emp_SalaryPeriod @relation(fields: [periodId], references: [id])
}

model Cli_Client {
  id               String        @id @default(uuid())
  businessName     String
  taxId            String        @unique
  email            String?
  phone            String?
  address          String?
  city             String?
  taxCondition     String?       @default("RI")
  paymentTermsDays Int           @default(30)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  checks           Cli_Check[]
  payments         Cli_Payment[]
  orders           Repo_Order[]
  sales            Sale_Order[]
}

model Cli_Payment {
  id             String            @id @default(uuid())
  clientId       String
  paymentDate    DateTime          @default(now())
  number         String?
  totalAmount    Float             @default(0.0)
  discountAmount Float             @default(0.0)
  paymentMethod  String            @default("EFECTIVO")
  referenceNotes String?
  status         String            @default("CONFIRMADO")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  checks         Cli_Check[]
  client         Cli_Client        @relation(fields: [clientId], references: [id])
  imputations    Cli_PaymentItem[]
}

model Cli_PaymentItem {
  id         String      @id @default(uuid())
  paymentId  String
  orderId    String?
  saleId     String?
  amountPaid Float       @default(0.0)
  order      Repo_Order? @relation(fields: [orderId], references: [id])
  payment    Cli_Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  sale       Sale_Order? @relation(fields: [saleId], references: [id])
}

model Cli_Check {
  id          String       @id @default(uuid())
  clientId    String
  paymentId   String?
  checkNumber String
  bankName    String
  issuerName  String?
  taxId       String?
  issueDate   DateTime
  dueDate     DateTime
  amount      Float
  status      String       @default("EN_CARTERA")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  client      Cli_Client   @relation(fields: [clientId], references: [id])
  payment     Cli_Payment? @relation(fields: [paymentId], references: [id])
}

model Repo_Order {
  id                 String            @id @default(uuid())
  orderNumber        Int               @unique @default(autoincrement())
  patent             String?
  vehicleBrand       String?
  pieceSummary       String?
  problemDescription String?
  priority           OrderPriority     @default(NORMAL)
  status             OrderStatus       @default(INGRESADO)
  clientId           String
  dueDate            DateTime?
  entryDate          DateTime          @default(now())
  finishDate         DateTime?
  deliveryDate       DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  imputations        Cli_PaymentItem[]
  client             Cli_Client        @relation(fields: [clientId], references: [id])
  tasks              Repo_Task[]

  @@index([patent])
}

model Repo_Task {
  id          String        @id @default(uuid())
  orderId     String
  pieceName   String
  serviceName String
  mechanicId  Int?
  laborPrice  Float         @default(0.0)
  partsCost   Float         @default(0.0)
  totalPrice  Float         @default(0.0)
  isCompleted Boolean       @default(false)
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  mechanic    Emp_Employee? @relation(fields: [mechanicId], references: [id])
  order       Repo_Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Sale_Order {
  id               String            @id @default(uuid())
  invoiceNumber    String?
  remitoNumber     String?
  clientId         String
  status           SaleStatus        @default(PENDIENTE)
  isCOD            Boolean           @default(false)
  totalAmount      Float             @default(0.0)
  itemsDescription String?
  saleDate         DateTime          @default(now())
  dueDate          DateTime?
  shipDate         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  imputations      Cli_PaymentItem[]
  client           Cli_Client        @relation(fields: [clientId], references: [id])
}

enum InvoiceType {
  FACTURA_A
  FACTURA_B
  FACTURA_C
  NOTA_CREDITO
  NOTA_DEBITO
}

enum InvoiceStatus {
  PENDIENTE
  PAGADA_PARCIAL
  PAGADA
  VENCIDA
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  CHEQUE
}

enum PaymentStatus {
  BORRADOR
  CONFIRMADO
  ANULADO
}

enum CheckStatus {
  PENDIENTE
  DEPOSITADO
  ENTREGADO
  RECHAZADO
}

enum UserRole {
  ADMIN
  VIEWER
}

enum PayType {
  MONTHLY
  BIWEEKLY
}

enum OrderPriority {
  NORMAL
  MEDIA
  ALTA
  URGENTE
}

enum OrderStatus {
  INGRESADO
  PRESUPUESTO_PENDIENTE
  EN_REPARACION
  ESPERANDO_REPUESTOS
  LISTO
  ENTREGADO
  ANULADO
}

enum SaleStatus {
  PENDIENTE
  DESPACHADO
  EN_VIAJE
  COBRADO
  MUESTRA_PENDIENTE
  ANULADO
}
