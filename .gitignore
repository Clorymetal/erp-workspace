# Clorymetal ERP .gitignore

# Dependencies
node_modules/
/packages/*/node_modules
/modules/*/node_modules

# Build
dist/
build/
.next/
out/

# Env & Secrets (Security: Do NOT commit .env files)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# IDE & OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Database / Docker temporary data
postgresql/
data/
*.sqlite
*.sqlite-journal

# Prisma
# WE INCLUDE MIGRATIONS IN GIT FOR PRODUCTION DEPLOYMENT
# !prisma/migrations/
